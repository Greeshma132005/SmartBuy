# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Database (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:your-db-password@db.xxxxx.supabase.co:5432/postgres

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# Scraping
SCRAPER_API_KEY=
SCRAPING_DELAY_MIN=2.0
SCRAPING_DELAY_MAX=3.0
SCRAPING_INTERVAL_HOURS=6

# RapidAPI (Real-Time Product Search / Google Shopping)
RAPIDAPI_KEY=              # Get from https://rapidapi.com after subscribing to Real-Time Product Search

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com    # SMTP server host
SMTP_PORT=587                # 587 for TLS, 465 for SSL
SMTP_USERNAME=               # SMTP login email
SMTP_PASSWORD=               # App password (NOT your regular email password)
SMTP_FROM_EMAIL=             # From address shown to recipients
SMTP_FROM_NAME=SmartBuy      # From name shown to recipients
